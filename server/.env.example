# ── Server ──────────────────────────────────────────────────────────────────
PORT=5000

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/lawpoint

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRY=24h

# ── AI — provide at least one key; OpenAI is preferred, Gemini is the fallback ─
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Email (Nodemailer / Gmail SMTP) ──────────────────────────────────────────
# Leave blank to run in log-only mode (no real emails sent)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password

# ── SMS (Twilio) — optional; leave blank to skip SMS ─────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=+1xxxxxxxxxx

# ── CORS ─────────────────────────────────────────────────────────────────────
# URL of the React frontend dev server
CLIENT_ORIGIN=http://localhost:5173
